# CS Intelligence System — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# --- Mock mode (Sprint 1 — bypasses real API calls) ---
USE_MOCK_DATA=true

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Salesforce (Sprint 2) ---
SALESFORCE_USERNAME=user@ontop.com
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
SALESFORCE_DOMAIN=login          # use "test" for sandbox

# --- Zendesk (Sprint 2) ---
ZENDESK_SUBDOMAIN=ontop
ZENDESK_EMAIL=user@ontop.com
ZENDESK_API_TOKEN=

# --- Morpheus internal API (Sprint 2) ---
MORPHEUS_BASE_URL=https://morpheus.internal.ontop.com
MORPHEUS_API_KEY=

# --- n8n webhook (Sprint 2) ---
N8N_WEBHOOK_BASE_URL=https://n8n.ontop.com/webhook
N8N_WEBHOOK_SECRET=
